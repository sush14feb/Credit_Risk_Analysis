      <aliases enabled='yes' />
      <column caption='Default Status' datatype='string' name='[Calculation_0539362976976896]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [loan_status] = 1 THEN &quot;Default&quot;&#13;&#10;ELSE &quot;Approved&quot;&#13;&#10;END' />
      </column>
      <column caption='Default Rate' datatype='real' name='[Calculation_0539362979749889]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [loan_status] = 1 THEN 1 ELSE 0 END) / COUNT([loan_status])' />
      </column>
      <column caption='Risk Tier' datatype='string' name='[Calculation_0539362980020226]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [loan_grade] = &quot;A&quot; THEN &quot;Low Risk&quot;&#13;&#10;ELSEIF [loan_grade] = &quot;B&quot; THEN &quot;Low-Medium&quot;&#13;&#10;ELSEIF [loan_grade] = &quot;C&quot; THEN &quot;Medium&quot;&#13;&#10;ELSEIF [loan_grade] = &quot;D&quot; THEN &quot;Medium-High&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Debt_to_Income' datatype='real' name='[Calculation_0539363032723460]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[loan_amnt]/[person_income]*100' />
      </column>
      <column caption='Income Bracket' datatype='string' name='[Calculation_0539363041046534]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [person_income] &lt; 300000 THEN &quot;Low Income&quot;&#13;&#10;ELSEIF [person_income] &lt; 700000 THEN &quot;Medium Income&quot;&#13;&#10;ELSE &quot;High Income&quot;&#13;&#10;END' />
      </column>
      <column caption='credit_risk_dataset.csv' datatype='table' name='[__tableau_internal_object_id__].[credit_risk_dataset.csv_A779AE405ED044B999CAC15084492B22]' role='measure' type='quantitative' />
